<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".activities.PersonalInfo">

    <!-- Header -->
    <TextView
        android:id="@+id/tv_header_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/personal_info_title"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Profile Image -->
    <ImageView
        android:id="@+id/info_profile_image"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_header_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="@string/profile_picture_desc"
        tools:src="@tools:sample/avatars" />

    <!-- ScrollView for inputs -->
    <ScrollView
        android:id="@+id/scroll_view_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/info_profile_image"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btn_save_profile">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- Full Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/full_name_label"
                android:textSize="14sp"
                android:textColor="@color/black"
                android:layout_marginTop="8dp" />

            <EditText
                android:id="@+id/info_user_full_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName"
                android:hint="@string/full_name_hint"
                android:paddingVertical="12dp"
                android:textColor="@color/black"
                android:textSize="16sp"
                tools:text="Tom Ryan" />

            <!-- Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/email_address"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/info_user_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:background="@color/white"
                tools:text="tom.ryan@example.com" />

            <!-- Phone -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/phone_number_label"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:layout_marginTop="16dp" />

            <EditText
                android:id="@+id/info_user_phone_number"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="phone"
                android:hint="@string/phone_number_hint"
                android:paddingVertical="12dp"
                android:textColor="@color/black"
                android:textSize="16sp"
                tools:text="555-123-4567" />

            <!-- Role Spinner -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/role_label"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:layout_marginTop="16dp" />

            <Spinner
                android:id="@+id/info_user_role_spinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:paddingVertical="12dp"
                android:spinnerMode="dropdown"
                android:prompt="@string/select_role_prompt"
                android:background="@drawable/spinner_border" />

            <!-- Professional Fields Container -->
            <LinearLayout
                android:id="@+id/professional_fields_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:paddingTop="16dp">

                <!-- Experience -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/experience_years_label"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:layout_marginTop="16dp" />

                <EditText
                    android:id="@+id/info_user_experience_years"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:hint="@string/experience_years_hint"
                    android:paddingVertical="12dp"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    tools:text="5" />

                <!-- Skills -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/skills_label"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:layout_marginTop="16dp" />

                <EditText
                    android:id="@+id/info_user_skills"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:hint="@string/skills_hint"
                    android:minLines="2"
                    android:gravity="top|start"
                    android:paddingVertical="12dp"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    tools:text="Plumbing, Tiling, HVAC maintenance" />

                <!-- Description -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/description_label"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:layout_marginTop="16dp" />

                <EditText
                    android:id="@+id/info_user_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:hint="@string/description_hint"
                    android:minLines="3"
                    android:gravity="top|start"
                    android:paddingVertical="12dp"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    tools:text="Certified professional offering high-quality home repair and installation services..." />

                <!-- Service Category -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/service_category_label"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:layout_marginTop="16dp" />

                <Spinner
                    android:id="@+id/info_service_category_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:paddingVertical="12dp"
                    android:spinnerMode="dropdown"
                    android:prompt="@string/select_category_prompt"
                    android:background="@drawable/spinner_border" />

                <!-- Service Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/service_name_label"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:layout_marginTop="16dp" />

                <EditText
                    android:id="@+id/info_service_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:hint="@string/service_name_hint"
                    android:focusable="false"
                    android:paddingVertical="12dp"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    tools:text="General Plumbing" />

                <!-- Services RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_user_services"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="16dp" />

                <!-- Add Service Button -->
                <Button
                    android:id="@+id/btn_add_service"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/service_name_label"
                    android:layout_gravity="end"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Edit & Save Buttons -->
    <Button
        android:id="@+id/btn_save_profile"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/purple_500"
        android:text="@string/save_button"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btn_edit_profile"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/gray_500"
        android:text="@string/edit_profile_button"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:layout_marginEnd="8dp"
        app:layout_constraintBottom_toBottomOf="@id/btn_save_profile"
        app:layout_constraintEnd_toStartOf="@id/btn_save_profile" />

</androidx.constraintlayout.widget.ConstraintLayout>
