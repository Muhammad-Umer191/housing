<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F7F7"
    tools:context=".OnBoarding">

    <ImageView
        android:id="@+id/on_boarding_picture"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="@string/onboarding_graphic_description"
        android:scaleType="fitCenter"
        android:src="@drawable/onboarding_graphic_description"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/on_boarding_title"
        />

    <TextView
        android:id="@+id/on_boarding_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/on_boarding_info"
        android:gravity="center"
        android:textColor="@android:color/black"
        android:textSize="30sp"
        android:textStyle="bold"
        android:layout_marginTop="0dp"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        app:layout_constraintTop_toBottomOf="@id/on_boarding_picture"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/on_boarding_description"
        />

    <TextView
        android:id="@+id/on_boarding_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/moto"
        android:gravity="center"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:lineSpacingExtra="4dp"
        app:layout_constraintTop_toBottomOf="@id/on_boarding_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/next"
        />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/next"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginBottom="60dp"
        android:layout_marginTop="100dp"
        android:text="@string/greater_than"
        android:textSize="25sp"
        android:textColor="@color/white"
        android:padding="0dp"
        app:cornerRadius="25dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:backgroundTint="@color/purple_500"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />



</androidx.constraintlayout.widget.ConstraintLayout>
