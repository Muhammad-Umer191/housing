<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="300dp"
    android:layout_height="130dp"
    android:layout_marginEnd="16dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/offer_card_background_green"
        android:padding="16dp"
        >

        <ImageView
            android:id="@+id/offer_info_icon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/info"
            app:tint="@color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:contentDescription="@string/offer_info_description" />

        <TextView
            android:id="@+id/offer_service_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/offer_ac_service"
            android:textSize="12sp"
            android:textColor="@color/white"
            android:layout_marginStart="4dp"
            app:layout_constraintTop_toTopOf="@+id/offer_info_icon"
            app:layout_constraintBottom_toBottomOf="@+id/offer_info_icon"
            app:layout_constraintStart_toEndOf="@+id/offer_info_icon" />

        <TextView
            android:id="@+id/offer_main_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/get_25_percent"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@+id/offer_service_label"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/grab_offer_link"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/grab_offer_link"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:drawableTint="@color/white"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@+id/offer_main_text"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>