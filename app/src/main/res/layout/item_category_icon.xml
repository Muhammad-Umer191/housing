<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="80dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <View
        android:id="@+id/category_circle_background"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/rounded_circle_light_background"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />

    <ImageView
        android:id="@+id/category_icon"
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:src="@drawable/ac_repair"
        app:layout_constraintTop_toTopOf="@+id/category_circle_background"
        app:layout_constraintBottom_toBottomOf="@+id/category_circle_background"
        app:layout_constraintStart_toStartOf="@+id/category_circle_background"
        app:layout_constraintEnd_toEndOf="@+id/category_circle_background"
        android:contentDescription="@string/category_icon_description" />

    <TextView
        android:id="@+id/category_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/ac_repair"
        android:textSize="12sp"
        android:textColor="@color/black"
        app:layout_constraintTop_toBottomOf="@+id/category_circle_background"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />

</androidx.constraintlayout.widget.ConstraintLayout>